    makeMobileBtn("TeleportBtn",   "TELE\nPORT",     Color3.fromRGB(60, 180, 100),  doTeleport)
    makeMobileBtn("OptBtn",        "VISUAL",         Color3.fromRGB(160, 60, 220),  toggleOptimizator)

    -- Кнопка открытия интерфейса (мини, сверху)
