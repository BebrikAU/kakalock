    -- Заголовки
    local redTitle = Instance.new("TextLabel")
    redTitle.Name = "RedTitle"
    redTitle.Size = UDim2.new(1, -16, 0, 22)
    redTitle.Position = UDim2.new(0, 8, 0, 6)
    redTitle.BackgroundTransparency = 1
    redTitle.TextColor3 = Color3.fromRGB(255, 180, 180)
    redTitle.TextSize = 16
    redTitle.Font = Enum.Font.GothamBold
    redTitle.TextXAlignment = Enum.TextXAlignment.Left
    redTitle.Text = "Red Team:"
    redTitle.Parent = playersPanel

    local redList = Instance.new("ScrollingFrame")
    redList.Name = "RedList"
    redList.Size = UDim2.new(1, -16, 0.4, -4)
    redList.Position = UDim2.new(0, 8, 0, 28)
    redList.BackgroundTransparency = 1
    redList.BorderSizePixel = 0
    redList.ScrollBarThickness = 3
    redList.ScrollBarImageColor3 = Color3.fromRGB(255, 180, 180)
    redList.ScrollBarImageTransparency = 0.5
    redList.CanvasSize = UDim2.new(0, 0, 0, 0)
    redList.Parent = playersPanel

    local redLayout = Instance.new("UIListLayout")
    redLayout.FillDirection = Enum.FillDirection.Vertical
    redLayout.HorizontalAlignment = Enum.HorizontalAlignment.Left
    redLayout.VerticalAlignment = Enum.VerticalAlignment.Top
    redLayout.Padding = UDim.new(0, 2)
    redLayout.Parent = redList

    local blueTitle = Instance.new("TextLabel")
    blueTitle.Name = "BlueTitle"
    blueTitle.Size = UDim2.new(1, -16, 0, 22)
    blueTitle.Position = UDim2.new(0, 8, 0.53, 0)
    blueTitle.BackgroundTransparency = 1
    blueTitle.TextColor3 = Color3.fromRGB(180, 210, 255)
    blueTitle.TextSize = 16
    blueTitle.Font = Enum.Font.GothamBold
    blueTitle.TextXAlignment = Enum.TextXAlignment.Left
    blueTitle.Text = "Blue Team:"
    blueTitle.Parent = playersPanel

    local blueList = Instance.new("ScrollingFrame")
    blueList.Name = "BlueList"
    blueList.Size = UDim2.new(1, -16, 0.4, -6)
    blueList.Position = UDim2.new(0, 8, 0.53, 24)
    blueList.BackgroundTransparency = 1
    blueList.BorderSizePixel = 0
    blueList.ScrollBarThickness = 3
    blueList.ScrollBarImageColor3 = Color3.fromRGB(180, 210, 255)
    blueList.ScrollBarImageTransparency = 0.5
    blueList.CanvasSize = UDim2.new(0, 0, 0, 0)
    blueList.Parent = playersPanel

    local blueLayout = Instance.new("UIListLayout")
    blueLayout.FillDirection = Enum.FillDirection.Vertical
    blueLayout.HorizontalAlignment = Enum.HorizontalAlignment.Left
    blueLayout.VerticalAlignment = Enum.VerticalAlignment.Top
    blueLayout.Padding = UDim.new(0, 2)
    blueLayout.Parent = blueList

    -- Обновление списка игроков
    task.spawn(function()
        while task.wait(2) do
            if not playersPanel or not playersPanel.Parent then break end

            for _, child in pairs(redList:GetChildren()) do
                if child:IsA("TextLabel") then child:Destroy() end
            end
            for _, child in pairs(blueList:GetChildren()) do
                if child:IsA("TextLabel") then child:Destroy() end
            end

            local players = Players:GetPlayers()

            for _, plr in pairs(players) do
                if plr.Team then
                    local label = Instance.new("TextLabel")
                    label.Size = UDim2.new(1, 0, 0, 18)
                    label.BackgroundTransparency = 1
                    label.TextColor3 = Color3.fromRGB(235, 240, 255)
                    label.TextSize = 13
                    label.Font = Enum.Font.Gotham
                    label.TextXAlignment = Enum.TextXAlignment.Left
                    label.Text = "  " .. plr.Name

                    if plr.Team.Name == "Red" then
                        label.Parent = redList
                    elseif plr.Team.Name == "Blue" then
                        label.Parent = blueList
                    end
                end
            end

            redList.CanvasSize  = UDim2.new(0, 0, 0, redLayout.AbsoluteContentSize.Y + 4)
            blueList.CanvasSize = UDim2.new(0, 0, 0, blueLayout.AbsoluteContentSize.Y + 4)
        end
    end)

    ----------------------------------------------------------------
    -- Перетаскивание трёх панелей
    ----------------------------------------------------------------
    local draggingWM, dragStartWM, startPosWM
    watermark.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 then
            draggingWM  = true
            dragStartWM = input.Position
            startPosWM  = watermark.Position
        end
    end)

    local draggingSP, dragStartSP, startPosSP
    statsPanel.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 then
            draggingSP  = true
            dragStartSP = input.Position
            startPosSP  = statsPanel.Position
        end
    end)

    local draggingPP, dragStartPP, startPosPP
    playersPanel.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 then
            draggingPP  = true
            dragStartPP = input.Position
            startPosPP  = playersPanel.Position
        end
    end)

    UserInputService.InputChanged:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseMovement then
            if draggingWM then
                local delta = input.Position - dragStartWM
                watermark.Position = UDim2.new(
                    startPosWM.X.Scale, startPosWM.X.Offset + delta.X,
                    startPosWM.Y.Scale, startPosWM.Y.Offset + delta.Y
                )
                wmShadow.Position = watermark.Position + UDim2.new(0, 2, 0, 2)
            end
            if draggingSP then
                local delta = input.Position - dragStartSP
                statsPanel.Position = UDim2.new(
                    startPosSP.X.Scale, startPosSP.X.Offset + delta.X,
                    startPosSP.Y.Scale, startPosSP.Y.Offset + delta.Y
                )
            end
            if draggingPP then
                local delta = input.Position - dragStartPP
                playersPanel.Position = UDim2.new(
                    startPosPP.X.Scale, startPosPP.X.Offset + delta.X,
                    startPosPP.Y.Scale, startPosPP.Y.Offset + delta.Y
                )
                ppShadow.Position = playersPanel.Position + UDim2.new(0, 2, 0, 2)
            end
        end
    end)

    UserInputService.InputEnded:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 then
            draggingWM = false
            draggingSP = false
            draggingPP = false
        end
    end)

    interfaceGUI.Enabled = false
    print("PopStar: Interface created successfully")
end


