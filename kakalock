local function getBall()
    for _, v in pairs(workspace:GetDescendants()) do
        if (v.Name == "Ball" or v.Name == "Football") and v:IsA("BasePart") then
            return v
        end
    end
    return nil
end

local autoFarmShootArgs = {
    10,
    Vector3.new(20.22258879244327545, 0, 0),  -- Y=0: удар по земле
    Vector3.new(20.9273859858512878, 0, 0),   -- Y=0: удар по земле
    Vector3.new(15.45458984375, 0, 0),        -- Y=0: удар по земле
    false,
    false
}

local function autoFarmShoot()
    local remote = ReplicatedStorage:FindFirstChild("ShootRE")
    if remote then
        remote:FireServer(unpack(autoFarmShootArgs))
    end
end

local function toggleAutoFarm()
    autoFarmActive = not autoFarmActive

    if autoFarmActive then
        showNotification("AUTO FARM: ON")

        task.spawn(function()
            while autoFarmActive do
                local ball = getBall()
                local char = player.Character
                local root = char and char:FindFirstChild("HumanoidRootPart")

                if ball and root then
                    root.CFrame = ball.CFrame
                    task.wait(0.05)
                    autoFarmShoot()
                end

                task.wait(0.05)
            end
        end)
    else
        showNotification("AUTO FARM: OFF")
    end

    -- Обновляем визуал мобильной кнопки если есть
    pcall(function()
        if mobileGui then
            local btn = mobileGui:FindFirstChild("AutoFarmBtn", true)
            if btn then
                btn.BackgroundColor3 = autoFarmActive
                    and Color3.fromRGB(0, 180, 80)
                    or  Color3.fromRGB(50, 50, 70)
                btn.Text = autoFarmActive and "AUTO\nON" or "AUTO\nOFF"
            end
        end
    end)
end

