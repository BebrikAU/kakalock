local function toggleOptimizator()
    isOptimized = not isOptimized

    if isOptimized then
        -- Убираем все эффекты
        for _, obj in pairs(workspace:GetDescendants()) do
            if obj:IsA("ParticleEmitter") or obj:IsA("Fire") or obj:IsA("Smoke") or obj:IsA("Sparkles") then
                obj.Enabled = false
            end
        end

        -- Прячем декали/текстуры
        for _, obj in pairs(workspace:GetDescendants()) do
            if obj:IsA("Texture") or obj:IsA("Decal") then
                obj.Transparency = 1
            end
        end

        -- Меняем небо безопасно
        local sky = Lighting:FindFirstChildOfClass("Sky")
        if sky then
            sky.SkyboxBk = "rbxasset://textures/sky/sky_512_bk.tex"
            sky.SkyboxDn = "rbxasset://textures/sky/sky_512_dn.tex"
            sky.SkyboxFt = "rbxasset://textures/sky/sky_512_ft.tex"
            sky.SkyboxLf = "rbxasset://textures/sky/sky_512_lf.tex"
            sky.SkyboxRt = "rbxasset://textures/sky/sky_512_rt.tex"
            sky.SkyboxUp = "rbxasset://textures/sky/sky_512_up.tex"
        end

        showNotification("OPTIMIZATOR: ACTIVATED")
    else
        -- Восстанавливаем эффекты
        for _, obj in pairs(workspace:GetDescendants()) do
            if obj:IsA("ParticleEmitter") or obj:IsA("Fire") or obj:IsA("Smoke") or obj:IsA("Sparkles") then
                obj.Enabled = true
            end
        end

        showNotification("OPTIMIZATOR: DEACTIVATED")
    end
end

