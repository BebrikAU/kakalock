if isDesktop then
    print("PopStar: Initializing Desktop version...")

    createDesktopGUI()
    createInterface()
    interfaceGUI.Enabled = true
    isInterfaceVisible = true

    UserInputService.InputBegan:Connect(function(input, gameProcessed)
        if gameProcessed then return end

        if input.KeyCode == Enum.KeyCode.Tab then
            togglePlayersPanel()
            return
        end

        if input.KeyCode == Enum.KeyCode.RightShift then
            toggleGUI()
            return
        end

        -- Режим назначения бинда
        if waitingForBind then
            if input.KeyCode == Enum.KeyCode.Backspace then
                keybinds[waitingForBind] = nil
                showNotification("Bind removed")
            elseif input.KeyCode ~= Enum.KeyCode.Unknown then
                keybinds[waitingForBind] = input.KeyCode
                showNotification("Bind set: " .. input.KeyCode.Name:gsub("Enum.KeyCode.", ""))
            end
            if _G.updateAllButtons then _G.updateAllButtons() end
            waitingForBind = nil
            bindingButton  = nil
            return
        end

        -- Кастомные бинды
        for funcName, keyCode in pairs(keybinds) do
            if input.KeyCode == keyCode then
                if funcName == "toggleMetavision"  then toggleMetavision()
                elseif funcName == "toggleSpeed"   then toggleSpeed()
                elseif funcName == "doShot"        then doShot()
                elseif funcName == "doAutoFarm"    then toggleAutoFarm()
                elseif funcName == "doTeleport"    then doTeleport()
                elseif funcName == "toggleInterface"   then toggleInterface()
                elseif funcName == "toggleOptimizator" then toggleOptimizator()
                end
                return
            end
        end

        -- Дефолтные бинды
        if input.KeyCode == Enum.KeyCode.N and not keybinds.toggleMetavision then
            toggleMetavision()
        end
        if input.KeyCode == Enum.KeyCode.I and not keybinds.toggleInterface then
            toggleInterface()
        end
        if input.KeyCode == Enum.KeyCode.F and not keybinds.doAutoFarm then
            toggleAutoFarm()
        end
    end)
end

