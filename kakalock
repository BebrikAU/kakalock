-- Функция Optimizator
local function toggleOptimizator()
    isOptimized = not isOptimized
    
    if isOptimized then
        -- Убираем все эффекты
        for _, obj in pairs(workspace:GetDescendants()) do
            if obj:IsA("ParticleEmitter") or obj:IsA("Fire") or obj:IsA("Smoke") or obj:IsA("Sparkles") then
                obj.Enabled = false
            end
        end
        
        -- Убираем текстуры
        for _, obj in pairs(workspace:GetDescendants()) do
            if obj:IsA("Part") and obj.Texture then
                obj.Texture = ""
            end
        end
        
        -- Меняем небо
        Lighting.Sky.SkyboxBk = "rbxasset://textures/sky/sky_512_bk.tex"
        Lighting.Sky.SkyboxDn = "rbxasset://textures/sky/sky_512_dn.tex"
        Lighting.Sky.SkyboxFt = "rbxasset://textures/sky/sky_512_ft.tex"
        Lighting.Sky.SkyboxLf = "rbxasset://textures/sky/sky_512_lf.tex"
        Lighting.Sky.SkyboxRt = "rbxasset://textures/sky/sky_512_rt.tex"
        Lighting.Sky.SkyboxUp = "rbxasset://textures/sky/sky_512_up.tex"
        
        showNotification("OPTIMIZATOR: ACTIVATED")
    else
        -- Восстанавливаем эффекты
        for _, obj in pairs(workspace:GetDescendants()) do
            if obj:IsA("ParticleEmitter") or obj:IsA("Fire") or obj:IsA("Smoke") or obj:IsA("Sparkles") then
                obj.Enabled = true
            end
        end
        
        showNotification("OPTIMIZATOR: DEACTIVATED")
    end
end

-- Функции из вашего файла
local function toggleMetavision()
    metavisionEnabled = not metavisionEnabled
    
    if metavisionEnabled then
        player:SetAttribute("Metavision", true)
        player:SetAttribute("PabloMetavision", true)
        
        pcall(function()
            local rs = game:GetService("ReplicatedStorage")
            if rs:FindFirstChild("METAVISION_ACTIVATION") then
                rs.METAVISION_ACTIVATION:FireServer()
            end
        end)
        
        showNotification("METAVISION: ACTIVATED")
    else
        player:SetAttribute("Metavision", false)
        player:SetAttribute("PabloMetavision", false)
        
        pcall(function()
            local rs = game:GetService("ReplicatedStorage")
            if rs:FindFirstChild("METAVISION_DEACTIVATION") then
                rs.METAVISION_DEACTIVATION:FireServer()
            end
        end)
        
        showNotification("METAVISION: DEACTIVATED")
    end
end

local function lockSpeed()
    pcall(function()
        local character = player.Character
        if not character then return end
        
        local humanoid = character:FindFirstChildOfClass("Humanoid")
        if humanoid then
            originalWalkSpeed = humanoid.WalkSpeed
            isSpeedLocked = true
            
            while isSpeedLocked and task.wait(0.1) do
                if humanoid and humanoid.WalkSpeed ~= 65 then
                    humanoid.WalkSpeed = 65
                end
            end
        end
    end)
end

local function extendHitboxes()
    for _, obj in pairs(workspace:GetDescendants()) do
        if obj:IsA("BasePart") and (obj.Name:find("Hitbox") or obj.Name:find("Tackle")) then
            if not extendedHitboxes[obj] then
                extendedHitboxes[obj] = {
                    Size = obj.Size,
                    CanCollide = obj.CanCollide
                }
                
                obj.Size = obj.Size * 3
                obj.CanCollide = true
            end
        end
    end
end

local function restoreHitboxes()
    for obj, originalData in pairs(extendedHitboxes) do
        if obj and obj.Parent then
            obj.Size = originalData.Size
            obj.CanCollide = originalData.CanCollide
        end
    end
    extendedHitboxes = {}
end

local function doTackle()
    pcall(function()
        local character = player.Character
        if not character then return end
        
        local hrp = character:FindFirstChild("HumanoidRootPart")
        if not hrp then return end
        
        showNotification("TACKLE: ACTIVATED")
        
        local tackleBV = Instance.new("BodyVelocity")
        tackleBV.Name = "TackleBV"
        tackleBV.MaxForce = Vector3.new(4000, 0, 4000)
        tackleBV.Velocity = hrp.CFrame.LookVector * 150
        tackleBV.Parent = hrp
        
        local airTackleRemotes = {
            "AltTackle_RE", "IkkTrackle_RE", "TackleImpact_RE", "Tackle_RE",
            "TackleHit_RE", "TackleSliderE", "WCTackleCancel", "AltTackleFmit",
            "TackleCDRE", "TackleBeastCutscene"
        }
        
        local targets = {}
        
        local ball = workspace:FindFirstChild("Ball")
        if ball then
            table.insert(targets, ball)
        end
        
        local players = game:GetService("Players"):GetPlayers()
        for _, targetPlayer in pairs(players) do
            if targetPlayer ~= player and targetPlayer.Character then
                local targetHrp = targetPlayer.Character:FindFirstChild("HumanoidRootPart")
                if targetHrp then
                    local distance = (hrp.Position - targetHrp.Position).Magnitude
                    if distance < 50 then
                        table.insert(targets, targetHrp)
                    end
                end
            end
        end
        
        local remoteLocations = {
            game:GetService("ReplicatedStorage"), player.PlayerGui,
            player.Character, workspace, game:GetService("Lighting")
        }
        
        local activatedCount = 0
        
        for _, location in pairs(remoteLocations) do
            if location then
                for _, remote in pairs(location:GetDescendants()) do
                    if remote:IsA("RemoteEvent") then
                        for _, remoteName in pairs(airTackleRemotes) do
                            if remote.Name == remoteName then
                                pcall(function()
                                    for _, target in pairs(targets) do
                                        remote:FireServer(target)
                                        activatedCount = activatedCount + 1
                                    end
                                    remote:FireServer()
                                    activatedCount = activatedCount + 1
                                end)
                            end
                        end
                        
                        if remote.Name:lower():find("tackle") or 
                           remote.Name:lower():find("air") or 
                           remote.Name:lower():find("hit") then
                            pcall(function()
                                for _, target in pairs(targets) do
                                    remote:FireServer(target)
                                    activatedCount = activatedCount + 1
                                end
                                remote:FireServer()
                                activatedCount = activatedCount + 1
                            end)
                        end
                    end
                end
            end
        end
        
        extendHitboxes()
        
        if activatedCount > 0 then
            showNotification("Tackle: " .. activatedCount .. " events")
        else
            showNotification("Tackle: Movement activated")
        end
        
        task.delay(2, function()
            if tackleBV and tackleBV.Parent then
                tackleBV:Destroy()
            end
            restoreHitboxes()
        end)
    end)
end

local function doTeleport()
    pcall(function()
        local character = player.Character
        if not character then return end
        
        local hrp = character:FindFirstChild("HumanoidRootPart")
        if not hrp then return end
        
        local team = player.Team and player.Team.Name or "Default"
        local targetPosition = team == "Red" and Vector3.new(-2263.6, -25.5, 1029.0)
                          or team == "Blue" and Vector3.new(-2839.7, -25.5, 1029.6)
                          or Vector3.new(-2238.1218, -25.3756, 1050.0332)
        
        hrp.CFrame = CFrame.new(targetPosition)
        showNotification("TELEPORT: COMPLETE")
    end)
end

local function doLoki()
