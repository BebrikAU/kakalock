local function toggleSpeed()
    pcall(function()
        local character = player.Character
        if not character then return end

        local humanoid = character:FindFirstChildOfClass("Humanoid")
        if humanoid then
            if isSpeedLocked then
                isSpeedLocked = false
                task.wait(0.2)
                humanoid.WalkSpeed = originalWalkSpeed
                showNotification("SPEED: UNLOCKED (" .. originalWalkSpeed .. ")")
            else
                originalWalkSpeed = humanoid.WalkSpeed
                humanoid.WalkSpeed = 65
                isSpeedLocked = true

                task.spawn(function()
                    while isSpeedLocked and task.wait(0.1) do
                        local char = player.Character
                        if char then
                            local hum = char:FindFirstChildOfClass("Humanoid")
                            if hum and hum.WalkSpeed ~= 65 then
                                hum.WalkSpeed = 65
                            end
                        else
                            break
                        end
                    end
                end)

                showNotification("SPEED: LOCKED at 65")
            end
        end
    end)
end

local function setupSpeedProtection()
    local character = player.Character
    if not character then
        player.CharacterAdded:Wait()
        character = player.Character
    end

    local humanoid = character:WaitForChild("Humanoid")

    humanoid:GetPropertyChangedSignal("WalkSpeed"):Connect(function()
        if isSpeedLocked and humanoid.WalkSpeed ~= 65 then
            humanoid.WalkSpeed = 65
        end
    end)
end

