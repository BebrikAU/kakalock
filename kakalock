    ----------------------------------------------------------------
    -- Перетаскивание панелей (мышь + тач)
    ----------------------------------------------------------------
    local function makeDraggable(frame, shadowFrame)
        local dragging, dragStart, startPos

        local function onInputBegan(input)
            local isMouse = input.UserInputType == Enum.UserInputType.MouseButton1
            local isTouch = input.UserInputType == Enum.UserInputType.Touch
            if isMouse or isTouch then
                dragging = true
                dragStart = input.Position
                startPos  = frame.Position
            end
        end

        local function onInputChanged(input)
            local isMouse = input.UserInputType == Enum.UserInputType.MouseMovement
            local isTouch = input.UserInputType == Enum.UserInputType.Touch
            if dragging and (isMouse or isTouch) then
                local delta = input.Position - dragStart
                frame.Position = UDim2.new(
                    startPos.X.Scale, startPos.X.Offset + delta.X,
                    startPos.Y.Scale, startPos.Y.Offset + delta.Y
                )
                if shadowFrame then
                    shadowFrame.Position = frame.Position + UDim2.new(0, 2, 0, 2)
                end
            end
        end

        local function onInputEnded(input)
            local isMouse = input.UserInputType == Enum.UserInputType.MouseButton1
            local isTouch = input.UserInputType == Enum.UserInputType.Touch
            if isMouse or isTouch then
                dragging = false
            end
        end

        frame.InputBegan:Connect(onInputBegan)
        UserInputService.InputChanged:Connect(onInputChanged)
        UserInputService.InputEnded:Connect(onInputEnded)
    end

    makeDraggable(watermark, wmShadow)
    makeDraggable(statsPanel, nil)
    makeDraggable(playersPanel, ppShadow)

    interfaceGUI.Enabled = false
    print("PopStar: Interface created successfully")
end

