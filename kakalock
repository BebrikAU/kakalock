            -- Анимация нажатия
            TweenService:Create(btn, TweenInfo.new(0.1), {BackgroundTransparency = 0.4}):Play()
            task.delay(0.15, function()
                TweenService:Create(btn, TweenInfo.new(0.1), {BackgroundTransparency = 0.15}):Play()
            end)
            func()
        end)

        return btn
    end

