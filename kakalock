local function createDesktopGUI()
    print("PopStar: Creating Desktop GUI via GlassUI...")

    local ui = GlassUI.new("POPSTAR_GUI")

    local window, buttonsContainer = ui:createWindow({
        Name      = "MainFrame",
        Title     = "PopStar 2.0",
        Visible   = false,
        Draggable = true,
        Size      = UDim2.new(0, 320, 0, 380),
        Position  = UDim2.new(0.5, -160, 0.5, -190)
    })

    mainFrame = window

    local buttonUpdaters = {}

    local function createBoundButton(displayName, color, funcName, func)
        local buttonFrame, clickButton, buttonText =
            ui:createButton(buttonsContainer, displayName, color)

        local function updateButtonText()
            local bind = keybinds[funcName]
            if bind then
                buttonText.Text = displayName .. " [" .. bind.Name:gsub("Enum.KeyCode.", "") .. "]"
            else
                buttonText.Text = displayName
            end
        end

        buttonUpdaters[funcName] = updateButtonText
        updateButtonText()

        clickButton.MouseButton1Click:Connect(func)

        clickButton.MouseButton2Down:Connect(function()
            if waitingForBind == funcName then
                waitingForBind = nil
                bindingButton  = nil
                updateButtonText()
                showNotification("Bind cancelled")
            else
                waitingForBind = funcName
                bindingButton  = buttonText
                buttonText.Text = "..."
                showNotification("Press a key or Backspace to clear")
            end
        end)
    end

    createBoundButton("Metavision",  Color3.fromRGB(255, 100, 100), "toggleMetavision",  toggleMetavision)
    createBoundButton("Speed",       Color3.fromRGB(255, 220, 100), "toggleSpeed",       toggleSpeed)
    createBoundButton("Shot",        Color3.fromRGB(100, 200, 255), "doShot",            doShot)
    createBoundButton("Auto Farm",   Color3.fromRGB(100, 255, 160), "doAutoFarm",        toggleAutoFarm)
    createBoundButton("Teleport",    Color3.fromRGB(100, 255, 150), "doTeleport",        doTeleport)
    createBoundButton("Interface",   Color3.fromRGB(150, 255, 200), "toggleInterface",   toggleInterface)
    createBoundButton("Optimizator", Color3.fromRGB(200, 100, 255), "toggleOptimizator", toggleOptimizator)

    _G.updateAllButtons = function()
        for _, updater in pairs(buttonUpdaters) do
            updater()
        end
    end

    print("PopStar: Desktop GUI created (GlassUI)")
end

