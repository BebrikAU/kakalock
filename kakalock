-- Функция для переключения интерфейса
local function toggleInterface()
    if not interfaceGUI then
        createInterface()
    end
    
    isInterfaceVisible = not isInterfaceVisible
    interfaceGUI.Enabled = isInterfaceVisible
    
    showNotification("Interface: " .. (isInterfaceVisible and "ON" or "OFF"))
end

-- Создаем GUI только для ПК
if isDesktop then
    print("PopStar: Initializing Desktop version...")
    
    createDesktopGUI()
    createInterface()  -- Создаём интерфейс сразу
    interfaceGUI.Enabled = true  -- Включаем его по умолчанию
    isInterfaceVisible = true
    
    -- Привязываем открытие/закрытие к правому Shift
    UserInputService.InputBegan:Connect(function(input, gameProcessed)
        if gameProcessed then return end
        
        if input.KeyCode == Enum.KeyCode.RightShift then
            print("PopStar: RightShift pressed - toggling GUI")
            toggleGUI()
        end
    end)

    -- Система биндов клавиш
    UserInputService.InputBegan:Connect(function(input, gameProcessed)
        if gameProcessed then return end
        
        -- Если ожидаем назначения бинда
        if waitingForBind then
            if input.KeyCode == Enum.KeyCode.Backspace then
                -- Удаляем бинд
                keybinds[waitingForBind] = nil
                showNotification("Bind removed")
            elseif input.KeyCode ~= Enum.KeyCode.Unknown then
                -- Назначаем новый бинд
                keybinds[waitingForBind] = input.KeyCode
                showNotification("Bind set: " .. input.KeyCode.Name:gsub("Enum.KeyCode.", ""))
            end
            
            -- Обновляем текст кнопки и выходим из режима ожидания
            if _G.updateAllButtons then
                _G.updateAllButtons()
            end
            waitingForBind = nil
            bindingButton = nil
            return
        end
        
        -- Проверяем назначенные бинды
        for funcName, keyCode in pairs(keybinds) do
            if input.KeyCode == keyCode then
                if funcName == "toggleMetavision" then
                    toggleMetavision()
                elseif funcName == "toggleSpeed" then
                    toggleSpeed()
                elseif funcName == "doShot" then
                    doShot()
                elseif funcName == "doTackle" then
                    doTackle()
                elseif funcName == "doTeleport" then
                    doTeleport()
                elseif funcName == "toggleInterface" then
                    toggleInterface()
                elseif funcName == "toggleOptimizator" then
                    toggleOptimizator()
                end
                return
            end
        end
        
        -- Стандартный бинд для Metavision на N (если не назначен другой)
        if input.KeyCode == Enum.KeyCode.N and not keybinds.toggleMetavision then
            print("PopStar: N pressed - toggling Metavision")
            toggleMetavision()
        end
        
        -- Стандартный бинд для Interface на I (если не назначен другой)
        if input.KeyCode == Enum.KeyCode.I and not keybinds.toggleInterface then
            print("PopStar: I pressed - toggling Interface")
            toggleInterface()
        end
    end)

    -- Система перемещения GUI
    local dragging = false
    local dragStart, startPos

    mainFrame.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 then
            dragging = true
            dragStart = input.Position
            startPos = mainFrame.Position
            print("PopStar: Started dragging GUI")
        end
    end)

    UserInputService.InputChanged:Connect(function(input)
        if dragging and input.UserInputType == Enum.UserInputType.MouseMovement then
            local delta = input.Position - dragStart
            mainFrame.Position = UDim2.new(
                startPos.X.Scale, 
                startPos.X.Offset + delta.X, 
                startPos.Y.Scale, 
                startPos.Y.Offset + delta.Y
            )
        end
    end)

    UserInputService.InputEnded:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 then
            dragging = false
            print("PopStar: Stopped dragging GUI")
        end
    end)
end

-- Защита от сброса скорости
local function setupSpeedProtection()
    local character = player.Character
    if not character then
        player.CharacterAdded:Wait()
        character = player.Character
    end
    
    local humanoid = character:WaitForChild("Humanoid")
    
    humanoid:GetPropertyChangedSignal("WalkSpeed"):Connect(function()
        if isSpeedLocked and humanoid.WalkSpeed ~= 65 then
            humanoid.WalkSpeed = 65
        end
    end)
end

-- Инициализация защиты скорости
player.CharacterAdded:Connect(setupSpeedProtection)
if player.Character then
    setupSpeedProtection()
end

