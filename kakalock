        print("PopStar: GUI not created yet, creating now...")
        createDesktopGUI()
    end
    
    isGUIVisible = not isGUIVisible
    mainFrame.Visible = isGUIVisible
    
    print("PopStar: GUI visibility set to: " .. tostring(isGUIVisible))
    
